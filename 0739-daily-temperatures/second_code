class Solution {
    public int[] dailyTemperatures(int[] temperatures) {
        int n = temperatures.length;
        int[] result = new int[n];
        
        // Fast primitive array stack
        int[] stack = new int[n];
        int top = 0; // Points to the next empty slot (size of stack)
        
        for (int i = n - 1; i >= 0; i--) {
            // stack[top - 1] is equivalent to st.peek()
            while (top > 0 && temperatures[i] >= temperatures[stack[top - 1]]) {
                top--; // equivalent to st.pop()
            }
            
            if (top > 0) {
                result[i] = stack[top - 1] - i;
            }
            
            // Push current index onto the array stack
            stack[top] = i;
            top++;
        }
        
        return result;
    }
}
